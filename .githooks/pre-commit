#!/bin/bash
# Pre-commit hook: secrets scan, formatting, file size, and meta file checks.

errors=0

# ---------------------------------------------------------------------------
# 1. Secrets scan (all staged files)
# ---------------------------------------------------------------------------

staged_all=$(git diff --cached --name-only --diff-filter=d) || true

if [ -n "$staged_all" ]; then
    for file in $staged_all; do
        # Skip binary files
        if git show ":$file" | file - | grep -q 'binary'; then
            continue
        fi

        content=$(git show ":$file")

        # Private key headers
        if echo "$content" | grep -En 'BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY' > /dev/null 2>&1; then
            echo "ERROR: Private key header found in $file"
            echo "       Never commit private keys — add *.pem and *.key to .gitignore."
            errors=1
        fi

        # Public IPv4 addresses — skip private/loopback/version/Unity ranges
        if echo "$content" | grep -En '([0-9]{1,3}\.){3}[0-9]{1,3}' > /dev/null 2>&1; then
            matches=$(echo "$content" | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | grep -Ev '^(0|1\.0\.0\.0|127|10|192\.168|172\.(1[6-9]|2[0-9]|3[01])|999)\.')
            if [ -n "$matches" ]; then
                echo "ERROR: Public IP address found in $file: $matches"
                echo "       Use a placeholder like <vps-ip> in docs, or move the value to a GitHub secret."
                errors=1
            fi
        fi
    done
fi

# ---------------------------------------------------------------------------
# 2. C# formatting via CSharpier
# ---------------------------------------------------------------------------

staged_cs=$(git diff --cached --name-only --diff-filter=d -- '*.cs') || true

if [ -n "$staged_cs" ]; then
    if ! dotnet csharpier check $staged_cs 2>&1; then
        echo ""
        echo "Run 'dotnet csharpier format Assets/Scripts/ Assets/Tests/ server/' to fix formatting."
        errors=1
    fi
fi

# ---------------------------------------------------------------------------
# 3. File size gate (GitHub rejects files >= 100 MB)
# ---------------------------------------------------------------------------

MAX_FILE_SIZE=104857600  # 100 MB in bytes

for file in $staged_all; do
    file_size=$(git cat-file -s ":$file" 2>/dev/null) || continue
    if [ "$file_size" -ge "$MAX_FILE_SIZE" ]; then
        size_mb=$((file_size / 1048576))
        echo "ERROR: $file is ${size_mb} MB (>= 100 MB). Use Git LFS or reduce file size."
        errors=1
    fi
done

# ---------------------------------------------------------------------------
# 4. Meta file sync (every added/removed Asset needs its .meta paired)
# ---------------------------------------------------------------------------

staged_added=$(git diff --cached --name-only --diff-filter=A) || true
staged_deleted=$(git diff --cached --name-only --diff-filter=D) || true

for file in $staged_added; do
    case "$file" in
        Assets/*) ;;
        *) continue ;;
    esac
    case "$file" in
        *.meta) continue ;;
    esac

    meta="$file.meta"
    if ! git diff --cached --name-only | grep -qx "$meta"; then
        echo "ERROR: $file added without its .meta file ($meta)"
        errors=1
    fi
done

for file in $staged_deleted; do
    case "$file" in
        Assets/*) ;;
        *) continue ;;
    esac
    case "$file" in
        *.meta) continue ;;
    esac

    meta="$file.meta"
    if ! git diff --cached --name-only --diff-filter=D | grep -qx "$meta"; then
        echo "ERROR: $file removed but its .meta file ($meta) was not removed"
        errors=1
    fi
done

# ---------------------------------------------------------------------------

if [ $errors -ne 0 ]; then
    echo ""
    echo "Pre-commit check failed. Fix the issues above and re-stage."
    exit 1
fi
