#!/bin/bash
# Pre-commit hook: validate formatting of staged .cs files.
# Enforces .editorconfig rules that aren't caught by the IDE alone.

set -e

errors=0

# Get staged .cs files (added or modified, excluding deleted).
staged_cs=$(git diff --cached --name-only --diff-filter=d -- '*.cs') || true

if [ -z "$staged_cs" ]; then
    exit 0
fi

for file in $staged_cs; do
    # Check for tab characters (should use spaces per .editorconfig).
    if git show ":$file" | grep -Pn '\t' > /dev/null 2>&1; then
        echo "ERROR: Tab characters found in $file (use 4 spaces)"
        errors=1
    fi

    # Check for trailing whitespace.
    if git show ":$file" | grep -Pn ' +$' > /dev/null 2>&1; then
        echo "ERROR: Trailing whitespace found in $file"
        errors=1
    fi

    # Check for missing final newline.
    if [ -n "$(git show ":$file" | tail -c 1)" ]; then
        echo "ERROR: Missing final newline in $file"
        errors=1
    fi

    # Check for fully qualified System.Collections.Generic usage.
    if git show ":$file" | grep -Pn 'System\.Collections\.Generic\.' > /dev/null 2>&1; then
        # Exclude using statements — those are fine.
        if git show ":$file" | grep -Pn 'System\.Collections\.Generic\.' | grep -v '^\s*using ' > /dev/null 2>&1; then
            echo "WARNING: Fully qualified System.Collections.Generic usage in $file (add a using directive instead)"
            errors=1
        fi
    fi
done

if [ $errors -ne 0 ]; then
    echo ""
    echo "Pre-commit check failed. Fix the issues above and re-stage."
    exit 1
fi
