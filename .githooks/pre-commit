#!/bin/bash
# Pre-commit hook: formatting, file size, and meta file checks.

errors=0

# ---------------------------------------------------------------------------
# 1. C# formatting via CSharpier
# ---------------------------------------------------------------------------

staged_cs=$(git diff --cached --name-only --diff-filter=d -- '*.cs') || true

if [ -n "$staged_cs" ]; then
    # Check fully qualified System.Collections.Generic usage (CSharpier won't catch this).
    for file in $staged_cs; do
        if git show ":$file" | grep -Pn 'System\.Collections\.Generic\.' | grep -v '^\s*using ' > /dev/null 2>&1; then
            echo "ERROR: Fully qualified System.Collections.Generic usage in $file (add a using directive)"
            errors=1
        fi
    done

    # Run CSharpier on staged .cs files.
    if ! dotnet csharpier check $staged_cs 2>&1; then
        echo ""
        echo "Run 'dotnet csharpier format Assets/Scripts/ Assets/Tests/' to fix formatting."
        errors=1
    fi
fi

# ---------------------------------------------------------------------------
# 2. File size gate (GitHub rejects files >= 100 MB)
# ---------------------------------------------------------------------------

MAX_FILE_SIZE=104857600  # 100 MB in bytes

staged_all=$(git diff --cached --name-only --diff-filter=d) || true

for file in $staged_all; do
    file_size=$(git cat-file -s ":$file" 2>/dev/null) || continue
    if [ "$file_size" -ge "$MAX_FILE_SIZE" ]; then
        size_mb=$((file_size / 1048576))
        echo "ERROR: $file is ${size_mb} MB (>= 100 MB). Use Git LFS or reduce file size."
        errors=1
    fi
done

# ---------------------------------------------------------------------------
# 3. Meta file sync (every added/removed Asset needs its .meta paired)
# ---------------------------------------------------------------------------

staged_added=$(git diff --cached --name-only --diff-filter=A) || true
staged_deleted=$(git diff --cached --name-only --diff-filter=D) || true

for file in $staged_added; do
    case "$file" in
        Assets/*) ;;
        *) continue ;;
    esac
    case "$file" in
        *.meta) continue ;;
    esac

    meta="$file.meta"
    if ! git diff --cached --name-only | grep -qx "$meta"; then
        echo "ERROR: $file added without its .meta file ($meta)"
        errors=1
    fi
done

for file in $staged_deleted; do
    case "$file" in
        Assets/*) ;;
        *) continue ;;
    esac
    case "$file" in
        *.meta) continue ;;
    esac

    meta="$file.meta"
    if ! git diff --cached --name-only --diff-filter=D | grep -qx "$meta"; then
        echo "ERROR: $file removed but its .meta file ($meta) was not removed"
        errors=1
    fi
done

# ---------------------------------------------------------------------------

if [ $errors -ne 0 ]; then
    echo ""
    echo "Pre-commit check failed. Fix the issues above and re-stage."
    exit 1
fi
