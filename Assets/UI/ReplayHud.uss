/* ReplayHud-specific styles. Shared components live in Shared.uss. */

/* ── Highlight button overrides ───────────────────────────────────── */
/* Overrides the fixed 48px width so the button fits its text label. */
.rh-highlight-btn {
    top: 16px;
    right: 16px;
    width: auto;
    padding: 0 16px;
    font-size: 16px;
}

.rh-highlight-btn--active {
    color: var(--highlight-cyan);
    background-color: var(--highlight-cyan-bg);
}

.rh-highlight-btn--active:hover {
    background-color: var(--highlight-cyan-bg-hover);
}

/* ── Controls toggle button ───────────────────────────────────────── */
.rh-controls-toggle {
    position: absolute;
    bottom: 100px;
    right: 16px;
    width: 40px;
    height: 28px;
    background-color: var(--bg-hud-panel);
    border-radius: 8px;
    border-width: 0;
    padding: 4px;
    align-items: center;
    justify-content: center;
}

.rh-controls-toggle:hover {
    background-color: var(--bg-loading-overlay);
}

.rh-controls-toggle-icon {
    width: 16px;
    height: 16px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: var(--text-secondary);
}

.rh-controls-toggle-icon--down {
    background-image: url("/Assets/Art/arrow_down.png");
}

.rh-controls-toggle-icon--up {
    background-image: url("/Assets/Art/arrow_up.png");
}

.rh-controls-bar--hidden {
    display: none;
}

/* ── Bottom controls bar ──────────────────────────────────────────── */
.rh-controls-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px 16px 16px;
    background-color: var(--bg-hud-panel);
}

/* Seek row */
.rh-seek-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.rh-time-label {
    font-size: 14px;
    color: var(--text-secondary);
    width: 50px;
    -unity-text-align: middle-center;
    flex-shrink: 0;
}

.rh-seek-track {
    flex-grow: 1;
    height: 8px;
    background-color: var(--bg-track);
    border-radius: 4px;
    margin: 0 8px;
    overflow: visible;
}

.rh-seek-fill {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 0%;
    background-color: var(--accent-progress);
    border-radius: 4px;
}

.rh-seek-handle {
    position: absolute;
    top: -6px;
    width: 20px;
    height: 20px;
    background-color: var(--text-primary);
    border-radius: 10px;
    margin-left: -10px;
    left: 0%;
}

.rh-seek-handle:hover {
    background-color: var(--text-white);
}

/* Playback controls row */
.rh-playback-row {
    flex-direction: row;
    justify-content: center;
    align-items: center;
}

.rh-play-btn {
    width: 56px;
    height: 40px;
    background-color: var(--bg-item-hover);
    border-radius: 20px;
    border-width: 0;
    margin-right: 12px;
    align-items: center;
    justify-content: center;
}

.rh-play-btn:hover {
    background-color: var(--bg-btn-ghost-hover-strong);
}

.rh-play-icon {
    width: 20px;
    height: 20px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: var(--text-primary);
}

.rh-play-icon--play {
    background-image: url("/Assets/Art/play_icon.png");
}

.rh-play-icon--pause {
    background-image: url("/Assets/Art/pause_icon.png");
}

.rh-speed-btn {
    width: 48px;
    height: 36px;
    font-size: 16px;
    color: var(--text-secondary);
    background-color: var(--bg-btn-ghost);
    border-radius: 18px;
    border-width: 0;
    -unity-text-align: middle-center;
}

.rh-speed-btn:hover {
    color: var(--text-primary);
    background-color: var(--bg-track);
}
