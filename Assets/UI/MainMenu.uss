/* Root containers */
.screen {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
    padding: 24px 0;
    background-color: rgb(24, 24, 32);
}

.screen--hidden {
    display: none;
}

/* Title */
.title {
    width: 80%;
    max-width: 500px;
    height: 100px;
    margin-bottom: 60px;
    flex-shrink: 1;
    background-image: url("/Assets/Art/title.png");
    -unity-background-scale-mode: scale-to-fit;
}

/* Standard menu button */
.menu-btn {
    width: 300px;
    padding: 14px 0;
    margin: 6px 0;
    font-size: 28px;
    color: rgb(255, 255, 255);
    background-color: rgb(60, 60, 80);
    border-radius: 8px;
    border-width: 0;
    -unity-text-align: middle-center;
    flex-shrink: 1;
}

.menu-btn:hover {
    background-color: rgb(80, 80, 110);
}

.menu-btn:active {
    background-color: rgb(100, 100, 140);
}

/* Preset grid container (mode select) */
.preset-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 560px;
    margin-bottom: 16px;
}

/* Preset button (mode select) */
.preset-btn {
    width: 160px;
    height: 80px;
    padding: 8px 4px;
    margin: 6px;
    font-size: 18px;
    color: rgb(255, 255, 255);
    background-color: rgb(50, 70, 90);
    border-radius: 8px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.1);
    -unity-text-align: middle-center;
    white-space: normal;
}

.preset-btn:hover {
    background-color: rgb(60, 90, 120);
    border-color: rgba(255, 255, 255, 0.3);
}

.preset-btn--selected {
    background-color: rgb(70, 120, 160);
    border-color: rgb(120, 180, 240);
}

/* Custom preset card — spans 2 grid columns */
.preset-btn--custom {
    width: 332px;
    height: 80px;
    padding: 8px 12px;
    justify-content: center;
    align-items: stretch;
}

.preset-custom-title {
    font-size: 14px;
    color: rgb(180, 180, 200);
    margin-bottom: 4px;
    -unity-text-align: middle-center;
}

.preset-custom-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 2px;
}

.preset-custom-dim-label {
    font-size: 14px;
    color: rgb(200, 200, 210);
    width: 14px;
    margin-right: 4px;
    -unity-text-align: middle-center;
}

.custom-dim-slider {
    flex-grow: 1;
}

.preset-custom-dim-value {
    font-size: 14px;
    color: rgb(180, 180, 200);
    width: 30px;
    margin-left: 4px;
    -unity-text-align: middle-right;
}

/* Start button on mode select */
.start-btn {
    width: 300px;
    padding: 14px 0;
    margin-top: 16px;
    font-size: 30px;
    color: rgb(255, 255, 255);
    background-color: rgb(40, 120, 60);
    border-radius: 8px;
    border-width: 0;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    flex-shrink: 1;
}

.start-btn:hover {
    background-color: rgb(50, 150, 75);
}

.start-btn:active {
    background-color: rgb(60, 180, 90);
}

/* Continue button — teal accent to distinguish from "Play" / "New Board" */
.continue-btn {
    background-color: rgb(30, 100, 110);
}

.continue-btn:hover {
    background-color: rgb(40, 130, 145);
}

.continue-btn:active {
    background-color: rgb(50, 160, 180);
}

/* Secondary label inside modals (e.g. "Your current game will be lost.") */
.modal-sublabel {
    font-size: 20px;
    color: rgb(160, 160, 175);
    margin-bottom: 24px;
    -unity-text-align: middle-center;
}

/* Quit button (desktop only, top-left X) */
.quit-btn {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 48px;
    height: 48px;
    font-size: 28px;
    color: rgb(180, 180, 180);
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    border-width: 0;
    -unity-text-align: middle-center;
}

.quit-btn:hover {
    color: rgb(255, 255, 255);
    background-color: rgba(255, 255, 255, 0.15);
}

/* Info button (bottom-right) */
.info-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 48px;
    height: 48px;
    font-size: 28px;
    color: rgb(180, 180, 180);
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    border-width: 0;
    -unity-text-align: middle-center;
    -unity-font-style: bold-and-italic;
}

.info-btn:hover {
    color: rgb(255, 255, 255);
    background-color: rgba(255, 255, 255, 0.15);
}

/* Info panel (anchored above the info button) */
.info-panel {
    position: absolute;
    bottom: 72px;
    right: 16px;
    background-color: rgb(40, 40, 55);
    border-radius: 10px;
    padding: 16px 20px;
    align-items: flex-end;
}

.info-text {
    font-size: 16px;
    color: rgb(160, 160, 175);
    margin-bottom: 4px;
    -unity-text-align: upper-right;
}

.info-credit {
    color: rgb(200, 200, 210);
    margin-top: 12px;
    margin-bottom: 0;
}

.info-link {
    font-size: 16px;
    color: rgb(120, 180, 240);
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    padding: 4px 0;
    -unity-text-align: upper-right;

}

.info-link:hover {
    color: rgb(160, 210, 255);
}

/* Bottom-left link row */
.link-row {
    position: absolute;
    bottom: 16px;
    left: 16px;
    flex-direction: row;
    align-items: center;
}

.link-icon-btn {
    width: 48px;
    height: 48px;
    margin-left: 8px;
    padding: 7px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    border-width: 0;

}

.link-icon-btn:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

.link-icon-btn:hover .link-icon {
    -unity-background-image-tint-color: rgb(220, 220, 230);
}

.link-icon {
    flex-grow: 1;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: rgb(160, 160, 175);
}

.link-icon--github {
    background-image: url("/Assets/Art/Octicons-mark-github.svg.png");
}

.link-icon--discord {
    background-image: url("/Assets/Art/discord-white-icon.png");
}

/* Quit modal overlay */
.modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    align-items: center;
    justify-content: center;
}

.modal-box {
    background-color: rgb(40, 40, 55);
    border-radius: 12px;
    padding: 32px 48px;
    align-items: center;
}

.modal-label {
    font-size: 28px;
    color: rgb(255, 255, 255);
    margin-bottom: 24px;
}

.modal-buttons {
    flex-direction: row;
}

.modal-buttons .menu-btn {
    width: 120px;
    padding: 10px 0;
    font-size: 22px;
    margin: 0 8px;
}

/* Section label */
.section-label {
    font-size: 28px;
    color: rgb(200, 200, 210);
    margin-bottom: 16px;
    flex-shrink: 1;
}

/* Subtitle / placeholder text */
.placeholder-text {
    font-size: 24px;
    color: rgb(140, 140, 160);
    margin-bottom: 32px;
    flex-shrink: 1;
}

/* Settings rows */
.setting-row {
    width: 300px;
    margin-bottom: 24px;
    align-items: center;
}

.setting-label {
    font-size: 20px;
    color: rgb(200, 200, 210);
    margin-bottom: 8px;
}

.setting-slider {
    width: 100%;
}

.setting-value {
    font-size: 18px;
    color: rgb(140, 140, 160);
    margin-top: 4px;
}
