<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="Shared.uss" />
    <Style src="ReplayHud.uss" />

    <!-- Loading overlay -->
    <ui:VisualElement name="loading-overlay" class="loading-overlay">
        <ui:Label name="loading-label" class="loading-label" text="Loading..." />
        <ui:VisualElement class="loading-bar-track">
            <ui:VisualElement name="loading-bar-fill" class="loading-bar-fill" />
        </ui:VisualElement>
        <ui:Label name="loading-percent" class="loading-percent" text="" />
    </ui:VisualElement>

    <!-- Exit button (top-left) -->
    <ui:Button name="exit-btn" class="hud-icon-btn hud-icon-btn--top-left">
        <ui:VisualElement class="hud-icon-btn__icon icon--close" />
    </ui:Button>

    <!-- Highlight toggle (top-right, wider to fit text) -->
    <ui:Button name="highlight-btn" class="hud-icon-btn rh-highlight-btn" text="Clearable" />

    <!-- Controls toggle button (bottom-center, above controls bar) -->
    <ui:Button name="controls-toggle-btn" class="rh-controls-toggle">
        <ui:VisualElement name="controls-toggle-icon" class="rh-controls-toggle-icon rh-controls-toggle-icon--down" />
    </ui:Button>

    <!-- Bottom controls bar -->
    <ui:VisualElement name="controls-bar" class="rh-controls-bar">
        <!-- Time labels and seek slider -->
        <ui:VisualElement class="rh-seek-row">
            <ui:Label name="time-current" class="rh-time-label" text="0:00" />
            <ui:VisualElement class="rh-seek-track" name="seek-track">
                <ui:VisualElement name="seek-fill" class="rh-seek-fill" />
                <ui:VisualElement name="seek-handle" class="rh-seek-handle" />
            </ui:VisualElement>
            <ui:Label name="time-total" class="rh-time-label" text="0:00" />
        </ui:VisualElement>

        <!-- Playback controls -->
        <ui:VisualElement class="rh-playback-row">
            <ui:Button name="play-pause-btn" class="rh-play-btn">
                <ui:VisualElement name="play-pause-icon" class="rh-play-icon rh-play-icon--pause" />
            </ui:Button>
            <ui:Button name="speed-btn" class="rh-speed-btn" text="1x" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
