/* GameHud-specific styles. Shared components live in Shared.uss. */

/* modal--hidden is used by GameController to show/hide modals */
.modal--hidden {
    display: none;
}

.timer-label {
    position: absolute;
    bottom: 16px;
    left: 16px;
    font-size: 32px;
    color: rgb(140, 140, 140);
    -unity-font-style: bold;
    letter-spacing: 1px;
}

.timer-label--solving {
    color: rgb(255, 255, 255);
}

.timer-label--warning {
    color: rgb(200, 60, 60);
}
