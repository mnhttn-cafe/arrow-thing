<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="../Shared/Shared.uss" />
    <Style src="GameHud.uss" />

    <ui:VisualElement name="loading-overlay" class="loading-overlay">
        <ui:Label name="loading-label" class="loading-label" text="Generating..." />
        <ui:VisualElement class="loading-bar-track">
            <ui:VisualElement name="loading-bar-fill" class="loading-bar-fill" />
        </ui:VisualElement>
        <ui:Label name="loading-percent" class="loading-percent" text="" />
    </ui:VisualElement>

    <ui:Button name="back-to-menu-btn" class="hud-icon-btn hud-icon-btn--top-left">
        <ui:VisualElement class="hud-icon-btn__icon icon--close" />
    </ui:Button>
    <ui:Button name="retry-btn" class="hud-icon-btn hud-icon-btn--top-right">
        <ui:VisualElement class="hud-icon-btn__icon icon--refresh" />
    </ui:Button>
    <ui:Label name="timer-label" class="timer-label" text="15" />
    <ui:Button name="trail-toggle-btn" class="hud-icon-btn hud-icon-btn--bottom-right">
        <ui:VisualElement class="hud-icon-btn__icon icon--arrow-lane-preview" />
    </ui:Button>

    <ui:VisualElement name="retry-modal" class="modal-overlay screen--hidden">
        <ui:VisualElement class="modal-box">
            <ui:Label name="modal-title" class="modal-label" />
            <ui:VisualElement class="modal-buttons">
                <ui:Button name="modal-confirm-btn" class="modal-btn" />
                <ui:Button name="modal-cancel-btn" class="modal-btn" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>

    <ui:VisualElement name="leave-modal" class="modal-overlay screen--hidden">
        <ui:VisualElement class="modal-box">
            <ui:Label name="modal-title" class="modal-label" />
            <ui:Label name="modal-subtitle" class="modal-sublabel screen--hidden" />
            <ui:VisualElement class="modal-buttons">
                <ui:Button name="modal-confirm-btn" class="modal-btn" />
                <ui:Button name="modal-cancel-btn" class="modal-btn" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>

    <ui:VisualElement name="cancel-generation-modal" class="modal-overlay modal--hidden">
        <ui:VisualElement class="modal-box">
            <ui:Label class="modal-label" text="Cancel generation?" />
            <ui:VisualElement class="modal-buttons">
                <ui:Button name="cancel-generation-yes-btn" class="modal-btn" text="Yes" />
                <ui:Button name="cancel-generation-no-btn" class="modal-btn" text="No" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
