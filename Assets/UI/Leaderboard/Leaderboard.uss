/* Leaderboard-specific styles. Shared components live in Shared.uss. */

/* Root screen */
.lb-screen {
    flex-grow: 1;
    background-color: var(--bg-screen);
    padding: 16px;
    overflow: hidden;
    height: 100%;
}

.lb--hidden {
    display: none;
}

/* ── Spacing overrides for shared components ──────────────────────── */

.lb-screen .screen-header {
    margin-bottom: 12px;
}

.lb-screen .tab-bar {
    margin-bottom: 8px;
}

.lb-screen .filter-row {
    margin-bottom: 10px;
}

/* ── Compact modal overrides ──────────────────────────────────────── */
/* The leaderboard modal is more compact than the default shared modal. */

.lb-screen .modal-box {
    padding: 28px 40px;
}

.lb-screen .modal-label {
    font-size: 20px;
    margin-bottom: 20px;
}

.lb-screen .modal-btn {
    width: 100px;
    font-size: 16px;
    border-radius: 6px;
    margin: 0 6px;
}

/* ── Scroll area ──────────────────────────────────────────────────── */

.lb-scroll {
    flex-grow: 1;
    flex-shrink: 1;
}

/* Scrollbar styling */
.lb-scroll .unity-scroller--vertical {
    width: 8px;
    margin: 0;
    padding: 0;
}

.lb-scroll .unity-scroller--vertical .unity-slider {
    margin: 0;
    padding: 0;
}

.lb-scroll .unity-scroller--vertical .unity-base-slider__tracker {
    background-color: var(--scrollbar-track);
    border-width: 0;
}

.lb-scroll .unity-scroller--vertical .unity-base-slider__dragger {
    background-color: var(--scrollbar-thumb);
    border-radius: 4px;
    border-width: 0;
}

.lb-scroll .unity-scroller--vertical .unity-base-slider__dragger:hover {
    background-color: var(--scrollbar-thumb-hover);
}

.lb-scroll .unity-scroller--vertical .unity-repeat-button {
    display: none;
    height: 0;
    min-height: 0;
}

.lb-list {
    flex-direction: column;
}

/* ── Entry rows ───────────────────────────────────────────────────── */

.lb-entry {
    flex-direction: row;
    align-items: center;
    padding: 8px 8px;
    margin-bottom: 2px;
    background-color: var(--bg-row);
    border-radius: 6px;
}

.lb-entry:hover {
    background-color: var(--bg-row-hover);
}

.lb-entry--gold {
    background-color: var(--rank-gold-bg);
}

.lb-entry--gold:hover {
    background-color: var(--rank-gold-bg-hover);
}

.lb-entry--silver {
    background-color: var(--rank-silver-bg);
}

.lb-entry--silver:hover {
    background-color: var(--rank-silver-bg-hover);
}

.lb-entry--bronze {
    background-color: var(--rank-bronze-bg);
}

.lb-entry--bronze:hover {
    background-color: var(--rank-bronze-bg-hover);
}

.lb-entry--favorite {
    background-color: var(--row-favorite-bg);
}

.lb-entry--favorite:hover {
    background-color: var(--row-favorite-bg-hover);
}


.lb-rank {
    font-size: 14px;
    color: var(--text-dim);
    width: 28px;
    -unity-text-align: middle-left;
    flex-shrink: 0;
}

.lb-rank--gold {
    color: var(--rank-gold);
}

.lb-rank--silver {
    color: var(--rank-silver);
}

.lb-rank--bronze {
    color: var(--rank-bronze);
}

.lb-size {
    font-size: 13px;
    color: var(--text-dim);
    width: 52px;
    -unity-text-align: middle-left;
    flex-shrink: 0;
}

.lb-time {
    font-size: 16px;
    color: var(--text-primary);
    width: 90px;
    -unity-text-align: middle-left;
    flex-shrink: 0;
}

.lb-name {
    font-size: 16px;
    color: var(--text-primary);
    flex-grow: 1;
    -unity-text-align: middle-left;
    overflow: hidden;
}

.lb-date {
    font-size: 12px;
    color: var(--text-dim);
    width: 62px;
    -unity-text-align: middle-right;
    flex-shrink: 0;
    margin-right: 4px;
}

/* ── Compact mode (narrow screens) ───────────────────────────────── */
/* Hides inline favorite / play buttons — those actions move to the context menu. */

.lb-screen--compact .lb-fav-btn {
    display: none;
}

.lb-screen--compact .lb-play-btn {
    display: none;
}

/* ── Row icon buttons (26px circular) ────────────────────────────── */
/* Base for small circular icon buttons in entry rows. */

.lb-row-btn {
    width: 26px;
    height: 26px;
    padding: 5px;
    background-color: var(--bg-btn);
    border-radius: 13px;
    border-width: 0;
    flex-shrink: 0;
    margin-right: 2px;
}

.lb-row-btn:hover {
    background-color: var(--bg-btn-hover);
}

.lb-row-btn__icon {
    flex-grow: 1;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: var(--text-secondary);
}

/* Favorite — transparent by default, shows bg on hover */
.lb-fav-btn {
    padding: 4px;
    background-color: transparent;
}

.lb-fav-btn:hover {
    background-color: var(--bg-btn);
}

.lb-fav-icon--on {
    background-image: url("/Assets/Art/Icons/favorite_on.png");
    -unity-background-image-tint-color: var(--accent-favorite);
}

.lb-fav-icon--off {
    background-image: url("/Assets/Art/Icons/favorite_off.png");
    -unity-background-image-tint-color: var(--text-secondary);
}

/* Play */
.lb-play-icon {
    background-image: url("/Assets/Art/Icons/play.png");
}

/* Context trigger (no right margin — last in row) */
.lb-ctx-trigger {
    margin-right: 0;
}

.lb-ctx-trigger-icon {
    background-image: url("/Assets/Art/Icons/context_menu.png");
}

/* ── Refresh button (in tab bar) ─────────────────────────────────── */

.lb-refresh-btn {
    width: 30px;
    height: 30px;
    padding: 5px;
    background-color: var(--bg-btn);
    border-radius: 15px;
    border-width: 0;
    flex-shrink: 0;
    margin-left: 6px;
}

.lb-refresh-btn:hover {
    background-color: var(--bg-btn-hover);
}

.lb-refresh-btn:active {
    background-color: var(--bg-btn-active);
}

.lb-refresh-icon {
    flex-grow: 1;
    background-image: url("/Assets/Art/Icons/refresh.png");
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: var(--text-secondary);
}

/* ── Toast position (bottom-center of leaderboard) ─────────────────── */
/* Base toast styles live in Shared.uss (.toast, .toast__text) */

.lb-screen .toast {
    bottom: 16px;
    left: 50%;
    translate: -50% 0;
}

/* ── Player panel (global view) ──────────────────────────────────── */

.lb-player-panel {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 12px 16px;
    margin-top: 8px;
    background-color: var(--bg-panel);
    border-radius: 8px;
    flex-shrink: 0;
}

.lb-player-panel-label {
    font-size: 15px;
    color: var(--text-secondary);
    -unity-text-align: middle-center;
    white-space: normal;
    flex-shrink: 1;
}

/* Larger variant (30px) for player panel — keep separate from .lb-row-btn (26px) */
.lb-player-play-btn {
    width: 30px;
    height: 30px;
    padding: 6px;
    background-color: var(--bg-btn);
    border-radius: 15px;
    border-width: 0;
    flex-shrink: 0;
    margin-left: 10px;
}

.lb-player-play-btn:hover {
    background-color: var(--bg-btn-hover);
}

.lb-player-panel-label--link {
    color: var(--accent-info);
}

.lb-player-panel-label--link:hover {
    color: var(--accent-info-btn-hover);
}

/* ── Entry highlight (player's own row in global view) ───────────── */

.lb-entry--highlight {
    border-left-width: 3px;
    border-left-color: var(--accent-info-btn);
}

/* ── Coming soon overlay ──────────────────────────────────────────── */

.lb-coming-soon {
    flex-grow: 1;
    background-color: var(--bg-loading-overlay);
    align-items: center;
    justify-content: center;
}

.lb-coming-soon-text {
    font-size: 32px;
    color: var(--text-dim);
    -unity-font-style: bold;
}
