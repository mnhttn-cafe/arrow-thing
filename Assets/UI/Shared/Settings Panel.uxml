<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="Shared.uss" />
    <Style src="../MainMenu/MainMenu.uss" />

    <ui:Template name="SettingsScreen" src="project://database/Assets/UI/MainMenu/SettingsScreen.uxml" />
    <ui:Template name="ConfirmModal" src="project://database/Assets/UI/Shared/ConfirmModal.uxml" />

    <!-- Settings overlay (absolute, over all scenes) -->
    <ui:Instance template="SettingsScreen" name="settings" class="overlay-instance screen--hidden" />

    <!-- Modals owned by SettingsController -->
    <ui:Instance template="ConfirmModal" name="clear-scores-modal" class="modal-instance" />
    <ui:Instance template="ConfirmModal" name="external-link-modal" class="modal-instance" />
    <ui:Instance template="ConfirmModal" name="logout-modal" class="modal-instance" />
</ui:UXML>
