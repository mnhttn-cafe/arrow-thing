    <Compile Include="../Assets/Scripts/Domain/Models/Arrow.cs" />
    <Compile Include="../Assets/Scripts/Domain/Models/Board.cs" />
    <Compile Include="../Assets/Scripts/Domain/BoardGeneration.cs" />
    <Compile Include="Program.cs" />
  </ItemGroup>
</Project>
