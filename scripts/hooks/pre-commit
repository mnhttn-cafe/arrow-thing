#!/bin/bash
# Pre-commit hook: validate formatting of staged .cs files.
# Enforces .editorconfig rules that aren't caught by the IDE alone.

set -e

errors=0

# ── Secrets scan (all staged files) ─────────────────────────────────────────
# Runs before the early-exit so it catches non-.cs files too.

staged_all=$(git diff --cached --name-only --diff-filter=d) || true

if [ -n "$staged_all" ]; then
    for file in $staged_all; do
        # Skip binary files
        if git show ":$file" | file - | grep -q 'binary'; then
            continue
        fi

        content=$(git show ":$file")

        # Private key headers
        if echo "$content" | grep -En 'BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY' > /dev/null 2>&1; then
            echo "ERROR: Private key header found in $file"
            echo "       Never commit private keys — add *.pem and *.key to .gitignore."
            errors=1
        fi

        # Public IPv4 addresses — matches dotted-quad IPs, skips private/loopback/version ranges
        # Exclusions: 0.x, 127.x, 10.x, 192.168.x, 172.16-31.x, 999.x (version strings)
        if echo "$content" | grep -En '([0-9]{1,3}\.){3}[0-9]{1,3}' > /dev/null 2>&1; then
            matches=$(echo "$content" | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | grep -Ev '^(0|127|10|192\.168|172\.(1[6-9]|2[0-9]|3[01])|999)\.')
            if [ -n "$matches" ]; then
                echo "ERROR: Public IP address found in $file: $matches"
                echo "       Use a placeholder like <vps-ip> in docs, or move the value to a GitHub secret."
                errors=1
            fi
        fi
    done
fi

# Get staged .cs files (added or modified, excluding deleted).
staged_cs=$(git diff --cached --name-only --diff-filter=d -- '*.cs') || true

if [ -z "$staged_cs" ]; then
    if [ $errors -ne 0 ]; then
        echo ""
        echo "Pre-commit check failed. Fix the issues above and re-stage."
        exit 1
    fi
    exit 0
fi

for file in $staged_cs; do
    # Check for tab characters (should use spaces per .editorconfig).
    if git show ":$file" | grep -Pn '\t' > /dev/null 2>&1; then
        echo "ERROR: Tab characters found in $file (use 4 spaces)"
        errors=1
    fi

    # Check for trailing whitespace.
    if git show ":$file" | grep -Pn ' +$' > /dev/null 2>&1; then
        echo "ERROR: Trailing whitespace found in $file"
        errors=1
    fi

    # Check for missing final newline.
    if [ -n "$(git show ":$file" | tail -c 1)" ]; then
        echo "ERROR: Missing final newline in $file"
        errors=1
    fi

    # Check for fully qualified System.Collections.Generic usage.
    if git show ":$file" | grep -Pn 'System\.Collections\.Generic\.' > /dev/null 2>&1; then
        # Exclude using statements — those are fine.
        if git show ":$file" | grep -Pn 'System\.Collections\.Generic\.' | grep -v '^\s*using ' > /dev/null 2>&1; then
            echo "WARNING: Fully qualified System.Collections.Generic usage in $file (add a using directive instead)"
            errors=1
        fi
    fi
done

if [ $errors -ne 0 ]; then
    echo ""
    echo "Pre-commit check failed. Fix the issues above and re-stage."
    exit 1
fi
